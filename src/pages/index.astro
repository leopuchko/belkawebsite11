<script>
  // Groups tabs
  const tabs = document.querySelectorAll('.group-tab');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const id = (tab as HTMLElement).dataset.group;
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected','false'); });
      tab.classList.add('active');
      tab.setAttribute('aria-selected','true');
      document.querySelectorAll('.group-panel').forEach(p => ((p as HTMLElement).style.display = 'none'));
      const panel = document.getElementById(`panel-${id}`);
      if (panel) panel.style.display = 'grid';
    });
  });

  // Trial form
  const form = document.getElementById('trialForm') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const fields = document.getElementById('trialFields');
    const success = document.getElementById('trialSuccess');
    if (fields) fields.style.display = 'none';
    if (success) success.style.display = 'block';
  });
</script>

