---
import BaseLayout from '../layouts/BaseLayout.astro';

const marqueeItems1 = ["Hip-Hop", "Breaking", "Acro", "Stretch", "Crew", "Battles", "Performances", "Витебск", "с 1997", "Belka"];
const marqueeItems2 = ["Belka Crew", "от 4 до 45+", "Витебск · Belka", "Hip-Hop / Breaking / Acro", "2026 / 27 SEASON"];

const stylesData = [
  { n: "01", name: "Hip-Hop", ital: "& Choreo", desc: "Groove, OG-style, choreo. База, на которой держится всё остальное.", tag: "5+ групп", thumb: "hop" },
  { n: "02", name: "Breaking", ital: "Bboy / Bgirl", desc: "Олимпийская дисциплина. Footwork, power, freezes — джемы и батлы.", tag: "4 группы", thumb: "break" },
  { n: "03", name: "Acrobatics", ital: "Acro", desc: "Колёса, рондаты, фляки, стойки. Маты, страховка, тренер рядом.", tag: "3 группы", thumb: "acro" },
  { n: "04", name: "Stretch", ital: "& Body", desc: "Растяжка и мобилити. Идеально как «второе занятие» в неделю.", tag: "2 группы", thumb: "stretch" },
];

const crewData = [
  { name: "Имя Тренера", role: "Hip-Hop · Head Coach", bio: "Призёр чемпионатов РБ. В Belka с 2016." },
  { name: "Имя Тренера", role: "Breaking · Bboy", bio: "Battle scene, RBC One Cypher." },
  { name: "Имя Тренера", role: "Acro · Спортивная гимнастика", bio: "КМС, безопасная страховка детей." },
  { name: "Имя Тренера", role: "Kids & Stretch", bio: "Работа с малышами и группой 30+." },
];

const stageTiles = [
  { cls: "t-1", title: "Отчётный концерт", when: "июнь 2025", bg: "#FF5C1A" },
  { cls: "t-2", title: "Чемпионат РБ Breaking", when: "апрель 2025", bg: "#F5F2EC" },
  { cls: "t-3", title: "Open jam", when: "пт", bg: "#0A0A0A" },
  { cls: "t-4", title: "Acro-шоу", when: "февраль", bg: "#FF5C1A" },
  { cls: "t-5", title: "Belka Crew Jr.", when: "Кубок Top Step", bg: "#F5F2EC" },
  { cls: "t-6", title: "Славянский базар", when: "лето 2024", bg: "#1a1a1a" },
];

const days = ["Пн", "Вт", "Ср", "Чт", "Пт", "Сб", "Вс"];
const times = ["16:00", "17:00", "18:00", "19:00", "20:00"];
type SchedClass = [string, string, string];
const sched: Record<string, Record<string, SchedClass>> = {
  "16:00": { "Пн":["hop","4–6","Мини"], "Ср":["hop","4–6","Мини"], "Пт":["hop","4–6","Мини"], "Сб":["acro","4–6","Acro малыши"] },
  "17:00": { "Пн":["hop","7–11","Hip-Hop Kids"], "Вт":["break","7–11","Break Kids"], "Ср":["hop","7–11","Hip-Hop Kids"], "Чт":["break","7–11","Break Kids"], "Сб":["hop","7–11","Hip-Hop Kids"] },
  "18:00": { "Пн":["acro","12–17","Acro Teens"], "Вт":["hop","12–17","Hip-Hop Teens"], "Ср":["acro","12–17","Acro Teens"], "Чт":["hop","12–17","Hip-Hop Teens"], "Пт":["break","12–17","Crew"], "Сб":["hop","12–17","Crew"] },
  "19:00": { "Пн":["hop","18+","Adult Hop"], "Вт":["break","18+","Break Adults"], "Ср":["hop","18+","Adult Hop"], "Чт":["break","18+","Break Adults"], "Пт":["hop","18+","Open Jam"] },
  "20:00": { "Вт":["hop","30+","30+ Hip-Hop"], "Чт":["hop","30+","30+ Hip-Hop"], "Сб":["acro","30+","30+ Stretch"] },
};

const groups = [
  { id: "mini",   age: "4–6",   label: "Мини",       title: "Танцевальный детский сад.", accent: "Первое касание сцены.", lead: "Раз в неделю по 45 минут. Игровая форма, ритмика, первая хореография.", bullets: ["Координация и чувство ритма","Первый отчётный концерт","Тренер с опытом с малышами"], price: 110, breakdown: [["Занятий в месяц","4"],["Длительность","45 мин"],["Размер группы","до 10"]], ribbon: "Хит" },
  { id: "kids",   age: "7–11",  label: "Дети",        title: "Hip-Hop / Acro / Break.", accent: "Выбор первого стиля.", lead: "Дважды в неделю по 60 минут. Базы, связки, первые выступления.", bullets: ["Полноценная база стиля","Первые батлы и фестивали","Команда Belka Crew Jr."], price: 160, breakdown: [["Занятий в месяц","8"],["Длительность","60 мин"],["Размер группы","до 12"]] },
  { id: "teens",  age: "12–17", label: "Подростки",   title: "Серьёзно и в команде.", accent: "Тренировки + выступления.", lead: "Три раза в неделю по 90 минут. Старшая команда — уже сборная.", bullets: ["Углублённая техника и фристайл","Чемпионаты РБ и высшие разряды","Тренерская ассистентура"], price: 195, breakdown: [["Занятий в месяц","12"],["Длительность","90 мин"],["Размер группы","до 14"]], ribbon: "Crew" },
  { id: "adults", age: "18–29", label: "Взрослые",    title: "Танцевать как для себя.", accent: "Без оценочности.", lead: "Вечерние группы после работы. 90 минут разгрузки.", bullets: ["Без обязательных выступлений","Гибкое посещение по абонементу","Открытые джемы по пятницам"], price: 175, breakdown: [["Занятий в месяц","8"],["Длительность","90 мин"],["Размер группы","до 16"]] },
  { id: "thirty", age: "30+",   label: "30+",          title: "Никогда не поздно.", accent: "Серьёзно — никогда.", lead: "Отдельная группа без подростковой суеты. Техника и удовольствие.", bullets: ["Тренер, понимающий тело 30+","Концерт «Belka 30+» каждый июнь","Без сравнений с детьми"], price: 175, breakdown: [["Занятий в месяц","8"],["Длительность","90 мин"],["Размер группы","до 14"]], ribbon: "Новое" },
];
---

<BaseLayout>

<!-- ══ NAV ══ -->
<header class="nav" id="top">
  <a href="#top" class="nav-brand">
    <img src="/logo-white.png" alt="Belka" width="36" height="36" />
    <span class="name">Belka</span>
  </a>
  <nav class="nav-links">
    <a href="#styles">Стили</a>
    <a href="#groups">Группы</a>
    <a href="#perf">Выступления</a>
    <a href="#alumni">Выпускники</a>
    <a href="#posters">Афиши</a>
    <a href="#schedule">Расписание</a>
    <a href="#contacts">Контакты</a>
  </nav>
  <div class="nav-cta">
    <a href="#trial" class="btn btn-primary btn-white">Пробное занятие</a>
  </div>
</header>

<!-- ══ HERO ══ -->
<section class="hero" id="hero">
  <div class="hero-squirrel-wrap">
    <img class="hero-bigsquirrel" src="/logo-orange.png" alt="" />
  </div>
  <div class="hero-stage">
    <div>
      <h1 class="hero-title">
        <span class="row">Dance</span>
        <span class="row out">like</span>
        <span class="row accent">Belka.</span>
      </h1>
    </div>
    <div class="hero-meta">
      <div class="cell"><div class="k">Стили</div><div class="v">Hip-Hop<br/>Breaking<br/><span class="accent">Acro</span></div></div>
      <div class="cell"><div class="k">Возраст</div><div class="v">от <span class="accent">4</span><br/>до 45+</div></div>
      <div class="cell"><div class="k">Группы</div><div class="v"><span class="accent">12</span> групп<br/>6 уровней</div></div>
      <div class="cell"><div class="k">Выступления</div><div class="v"><span class="accent">40+</span><br/>в год</div></div>
    </div>
    <div class="hero-actions">
      <a href="#trial" class="btn btn-primary btn-white">Записаться на пробное</a>
      <div class="hero-tick">
        <span class="dot"></span>
        <span>Сейчас идёт набор</span>
      </div>
    </div>
  </div>
</section>

<!-- ══ MARQUEE 1 (orange) ══ -->
<div class="marquee">
  <div class="track">
    {[...marqueeItems1, ...marqueeItems1].map((t) => (
      <span class="item">{t}<span class="dot" /></span>
    ))}
  </div>
</div>

<!-- ══ REEL ══ -->
<section class="reel" id="reel">
  <div class="reel-head shell">
    <div>
      <div class="eyebrow" style="margin-bottom:16px">/ Showreel</div>
      <h2 class="h2">Belka <span style="color:var(--orange)">в&nbsp;движении.</span></h2>
    </div>
    <p class="body-text" style="max-width:36ch">Живые выступления, отчётные концерты, чемпионаты.</p>
  </div>
  <div class="reel-stage shell">
    <span class="tag">Showreel · 2025</span>
    <div class="reel-placeholder ph-ink-stripe">
      <span class="ph-label">Showreel · видео или постер</span>
    </div>
    <div class="play" aria-hidden="true"></div>
    <div class="caption">
      <span class="ttl">Belka Crew · отчётный концерт</span>
      <span>02:34</span>
    </div>
  </div>
  <div class="reel-grid shell">
    <div class="reel-still ph-ink-stripe"><span class="ph-label">Кадр 1 · батл</span></div>
    <div class="reel-still ph-ink-stripe"><span class="ph-label">Кадр 2 · акро</span></div>
    <div class="reel-still ph-ink-stripe"><span class="ph-label">Кадр 3 · детская группа</span></div>
  </div>
</section>

<!-- ══ ABOUT ══ -->
<section class="about" id="about">
  <div class="col-l">
    <div class="num">/ 01 — О школе</div>
    <h2 class="h2">12 лет<br/><span class="o">в движении.</span></h2>
  </div>
  <div class="col-r">
    <p class="lead">Танцевальная семья из Витебска. Hip-Hop, Breaking и Acro — от первой тренировки до сцены.</p>
    <div class="stats">
      <div class="stat"><div class="n">1&nbsp;200+</div><div class="l">учеников</div></div>
      <div class="stat"><div class="n">23</div><div class="l">медали 2024–25</div></div>
      <div class="stat"><div class="n">3</div><div class="l">зала в центре</div></div>
    </div>
  </div>
</section>

<!-- ══ MARQUEE 2 (ink / reverse) ══ -->
<div class="marquee ink reverse">
  <div class="track">
    {[...marqueeItems2, ...marqueeItems2].map((t) => (
      <span class="item">{t}<span class="dot" /></span>
    ))}
  </div>
</div>

<!-- ══ STYLES ══ -->
<section class="styles" id="styles">
  <div class="styles-head">
    <div>
      <div class="eyebrow" style="margin-bottom:16px">/ 02 — Направления</div>
      <h2 class="h2">Четыре <span class="o">направления.</span></h2>
    </div>
    <p class="body-text" style="color:rgba(10,10,10,0.7);max-width:42ch">Можно одно. Можно комбинировать.</p>
  </div>
  {stylesData.map((s) => (
    <div class="style-row">
      <div class="style-num">{s.tag}<br/>{s.n}</div>
      <h3 class="style-name">{s.name} <span class="ital">{s.ital}</span></h3>
      <p class="style-meta">{s.desc}</p>
      <div class={`style-thumb thumb-${s.thumb}`}>
        {s.thumb === "hop" && (
          <svg viewBox="0 0 200 140" preserveAspectRatio="xMidYMid slice">
            <defs><pattern id="pHop" width="14" height="14" patternUnits="userSpaceOnUse"><rect width="14" height="14" fill="#0A0A0A"/><rect width="7" height="14" fill="#FF5C1A"/></pattern></defs>
            <rect width="200" height="140" fill="url(#pHop)"/>
            <circle cx="100" cy="70" r="40" fill="#F5F2EC"/>
            <text x="100" y="76" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#0A0A0A" letter-spacing="2">HIP-HOP</text>
          </svg>
        )}
        {s.thumb === "break" && (
          <svg viewBox="0 0 200 140" preserveAspectRatio="xMidYMid slice">
            <rect width="200" height="140" fill="#F5F2EC"/>
            <g stroke="#0A0A0A" stroke-width="1" fill="none">
              {Array.from({length:14},(_,i) => <line key={i} x1="0" y1={i*10} x2="200" y2={i*10+30}/>)}
            </g>
            <rect x="80" y="50" width="40" height="40" fill="#FF5C1A" transform="rotate(45 100 70)"/>
          </svg>
        )}
        {s.thumb === "acro" && (
          <svg viewBox="0 0 200 140" preserveAspectRatio="xMidYMid slice">
            <rect width="200" height="140" fill="#FF5C1A"/>
            {Array.from({length:8},(_,i) => <circle key={i} cx={25+i*22} cy="70" r={4+(i%3)*4} fill="#0A0A0A" opacity="0.8"/>)}
            <path d="M 0 100 Q 100 20 200 100" stroke="#0A0A0A" stroke-width="3" fill="none"/>
          </svg>
        )}
        {s.thumb === "stretch" && (
          <svg viewBox="0 0 200 140" preserveAspectRatio="xMidYMid slice">
            <rect width="200" height="140" fill="#0A0A0A"/>
            {Array.from({length:20},(_,i) => <line key={i} x1={i*12} y1="0" x2={i*12-40} y2="140" stroke="#FF5C1A" stroke-width="2" opacity="0.55"/>)}
          </svg>
        )}
        <span class="label">PHOTO · {s.name.toUpperCase()}</span>
      </div>
    </div>
  ))}
</section>

<!-- ══ CREW ══ -->
<section class="crew" id="crew">
  <div class="crew-head">
    <div>
      <div class="eyebrow" style="margin-bottom:16px">/ Тренеры</div>
      <h2 class="h2">Те, кто <span class="o">ведёт.</span></h2>
    </div>
    <p class="body-text" style="color:rgba(10,10,10,0.7)">Практикующие танцоры — тренеры с живой практикой.</p>
  </div>
  <div class="crew-grid">
    {crewData.map((c, i) => (
      <div class="crew-card">
        <div class={`crew-photo ph-${i % 2 === 0 ? 'ink' : 'orange'}-stripe`}>
          <span class="ph-label">{c.name}</span>
        </div>
        <div class="role">{c.role}</div>
        <h3 class="name">{c.name}</h3>
        <p class="bio">{c.bio}</p>
      </div>
    ))}
  </div>
</section>

<!-- ══ GROUPS ══ -->
<section class="groups" id="groups">
  <div class="groups-head">
    <div>
      <div class="eyebrow" style="margin-bottom:16px">/ 04 — Возрастные группы</div>
      <h2 class="h2">От <span class="o">4</span> до <span class="o">∞</span>.</h2>
    </div>
    <p class="body-text" style="color:rgba(10,10,10,0.7)">Hip-Hop, Breaking и Acro — на каждой возрастной ступени.</p>
  </div>

  <div class="group-tabs" role="tablist" id="groupTabs">
    {groups.map((g) => (
      <button class={`group-tab${g.id === 'kids' ? ' active' : ''}`} data-group={g.id} role="tab" aria-selected={g.id === 'kids' ? 'true' : 'false'}>
        <span class="age">{g.age}</span>
        <span>{g.label}</span>
      </button>
    ))}
  </div>

  {groups.map((g) => (
    <div class="group-panel" id={`panel-${g.id}`} style={g.id !== 'kids' ? 'display:none' : ''}>
      <div>
        <div class="pre">{g.label} · возраст {g.age}</div>
        <h3>{g.title}<br/><span class="o">{g.accent}</span></h3>
        <p class="lead">{g.lead}</p>
        <ul>
          {g.bullets.map((b) => <li>{b}</li>)}
        </ul>
      </div>
      <div class="group-card">
        {g.ribbon && <div class="ribbon">{g.ribbon}</div>}
        <div class="pre" style="font-family:var(--mono);font-size:11px;letter-spacing:0.18em;color:rgba(245,242,236,0.55);text-transform:uppercase;margin-bottom:14px">Абонемент</div>
        <div class="price"><span class="cur">BYN</span>{g.price}</div>
        <div class="per">в месяц</div>
        <div class="breakdown">
          {g.breakdown.map(([k, v]) => (
            <div class="brow"><span>{k}</span><span class="v">{v}</span></div>
          ))}
        </div>
        <div style="margin-top:28px">
          <a href="#trial" class="btn btn-primary" style="width:100%;justify-content:center">
            Записаться — {g.label.toLowerCase()} <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </div>
  ))}
</section>

<!-- ══ STAGE ══ -->
<section class="stage" id="perf">
  <div class="stage-head shell">
    <div>
      <div class="eyebrow" style="margin-bottom:16px">/ 05 — Сцена и медали</div>
      <h2 class="h2">Не репетируем <span style="color:var(--orange)">«в стол».</span></h2>
    </div>
    <p class="body-text" style="max-width:38ch">Каждый ученик — на сцене минимум 4 раза в год.</p>
  </div>
  <div class="stage-wall shell">
    {stageTiles.map((t) => (
      <div class={`tile ${t.cls}`} style={`background:${t.bg}`}>
        <div class="tile-inner" style={`background:${t.bg}`}></div>
        <div class="label">
          <span>{t.title}</span>
          <span class="when">{t.when}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- ══ ALUMNI ══ -->
<section class="alumni" id="alumni">
  <div class="alumni-head shell">
    <div>
      <div class="eyebrow" style="margin-bottom:16px">/ Гордость школы</div>
      <h2 class="h2">Звёздные <span style="color:var(--orange)">выпускники.</span></h2>
    </div>
    <p class="body-text" style="max-width:40ch">Наши ученики выходят на большую сцену — чемпионаты, клипы, профессиональные коллективы.</p>
  </div>
  <div class="alumni-panels shell">
    <div class="alumni-panel" tabindex="0">
      <div class="ap-bg ph-ink-stripe"></div>
      <div class="ap-overlay"></div>
      <div class="ap-content">
        <div class="ap-num">01</div>
        <div class="ap-info">
          <div class="ap-tag">Hip-Hop · Выпуск 2021</div>
          <div class="ap-name">Имя Выпускника</div>
          <div class="ap-ach">Чемпион РБ · Battle Pro 2023</div>
        </div>
      </div>
    </div>
    <div class="alumni-panel" tabindex="0">
      <div class="ap-bg ph-orange-stripe"></div>
      <div class="ap-overlay"></div>
      <div class="ap-content">
        <div class="ap-num">02</div>
        <div class="ap-info">
          <div class="ap-tag">Breaking · Выпуск 2019</div>
          <div class="ap-name">Имя Выпускника</div>
          <div class="ap-ach">Belka Crew · гастроли по РБ</div>
        </div>
      </div>
    </div>
    <div class="alumni-panel" tabindex="0">
      <div class="ap-bg ph-ink-stripe"></div>
      <div class="ap-overlay"></div>
      <div class="ap-content">
        <div class="ap-num">03</div>
        <div class="ap-info">
          <div class="ap-tag">Acro · Выпуск 2022</div>
          <div class="ap-name">Имя Выпускника</div>
          <div class="ap-ach">КМС · Чемпионат СНГ</div>
        </div>
      </div>
    </div>
    <div class="alumni-panel" tabindex="0">
      <div class="ap-bg ph-orange-stripe"></div>
      <div class="ap-overlay"></div>
      <div class="ap-content">
        <div class="ap-num">04</div>
        <div class="ap-info">
          <div class="ap-tag">Hip-Hop · Выпуск 2020</div>
          <div class="ap-name">Имя Выпускника</div>
          <div class="ap-ach">Постановщик · ТВ-проект</div>
        </div>
      </div>
    </div>
    <div class="alumni-panel" tabindex="0">
      <div class="ap-bg ph-ink-stripe"></div>
      <div class="ap-overlay"></div>
      <div class="ap-content">
        <div class="ap-num">05</div>
        <div class="ap-info">
          <div class="ap-tag">Breaking · Выпуск 2023</div>
          <div class="ap-name">Имя Выпускника</div>
          <div class="ap-ach">RBC One Cypher · финал</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ POSTERS ══ -->
<section class="posters" id="posters">
  <div class="posters-head">
    <div>
      <div class="eyebrow" style="margin-bottom:16px">/ Афиши и события</div>
      <h2 class="h2">Ближайшие <span class="o">события.</span></h2>
    </div>
    <a href="#trial" class="btn btn-ghost">Все события →</a>
  </div>
  <div class="posters-grid">
    <article class="poster-card poster-big">
      <div class="poster-img ph-orange-stripe"></div>
      <div class="poster-info">
        <div class="poster-date">14 ИЮНЯ 2026</div>
        <h3 class="poster-title">Отчётный концерт «BELKA × VITEBSK»</h3>
        <div class="poster-where">Концертный зал «Витебск» · 720 мест</div>
        <a href="#trial" class="btn btn-ink" style="margin-top:auto">Записаться <span class="arrow">→</span></a>
      </div>
    </article>
    <article class="poster-card">
      <div class="poster-img ph-ink-stripe"></div>
      <div class="poster-info">
