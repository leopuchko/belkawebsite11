/* Wrapper: позиция по right + top рассчитан так, чтобы центр белки
   совпал с центром заголовка (padding 140px + 3 строки × font × 0.86) */
.hero-squirrel-wrap {
  position: absolute;
  top: calc(140px + 1.29 * clamp(86px, 17vw, 280px) - min(50vw, 660px) / 2);
